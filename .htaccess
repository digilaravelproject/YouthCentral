<IfModule mod_rewrite.c>
    RewriteEngine On

    # Enforce HTTPS on non-local environments
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteCond %{HTTP_HOST} !^127\.0\.0\.1 [NC]
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Rewrite all requests to the public folder
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block access to sensitive files
<Files ".env">
    Order allow,deny
    Deny from all
</Files>
<Files "composer.json">
    Order allow,deny
    Deny from all
</Files>
<Files "composer.lock">
    Order allow,deny
    Deny from all
</Files>
<Files "artisan">
    Order allow,deny
    Deny from all
</Files>